---
const navLinks = [
  { label: "Experience", href: "#experience" },
  { label: "Projects", href: "#projects" },
  { label: "Skills", href: "#skills" },
  { label: "Education", href: "#education" },
  { label: "Contact", href: "#contact" },
];
---

<header class="sticky top-0 z-50 bg-stone-50/90 backdrop-blur-sm border-b border-zinc-200">
  <div class="max-w-3xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="#" class="text-sm font-semibold text-zinc-900 tracking-tight hover:text-zinc-600 transition-colors">
      Philip Mollerus
    </a>

    <!-- Desktop nav -->
    <nav class="hidden sm:flex items-center gap-6">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm text-zinc-500 hover:text-zinc-900 transition-colors"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Mobile nav toggle -->
    <button
      id="mobile-menu-toggle"
      class="sm:hidden text-zinc-500 hover:text-zinc-900 transition-colors"
      aria-label="Toggle menu"
    >
      <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
      <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Mobile dropdown -->
  <nav id="mobile-menu" class="hidden sm:hidden border-t border-zinc-200 bg-stone-50">
    <div class="max-w-3xl mx-auto px-6 py-3 flex flex-col gap-3">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm text-zinc-500 hover:text-zinc-900 transition-colors mobile-nav-link"
        >
          {link.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("icon-open");
  const iconClose = document.getElementById("icon-close");

  toggle?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden", isOpen);
    iconOpen?.classList.toggle("hidden", !isOpen);
    iconClose?.classList.toggle("hidden", isOpen);
  });

  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
      iconOpen?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
    });
  });
</script>
